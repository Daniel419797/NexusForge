{
  "name": "activity",
  "description": "Activities API for creating and managing activities",
  "requestSchema": {
    "type": "object",
    "properties": {
      "title": { "type": "string" },
      "description": { "type": "string" },
      "requiresTalentSubmission": { "type": "boolean" },
      "instructions": { "type": "string" },
      "maxSubmissionsPerParticipant": { "type": "integer" },
      "opensAt": { "type": "string", "format": "date-time" },
      "closesAt": { "type": "string", "format": "date-time" },
      "status": { "type": "string", "enum": ["draft","published","closed"] },
      "tokenCostToSubmit": { "type": "integer" },
      "metadata": { "type": "object" }
    },
    "required": ["title","description"]
  },
  "responseSchema": {
    "type": "object",
    "properties": {
      "activity": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "requiresTalentSubmission": { "type": "boolean" },
          "instructions": { "type": "string" },
          "maxSubmissionsPerParticipant": { "type": "integer" },
          "opensAt": { "type": "string", "format": "date-time" },
          "closesAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string" },
          "createdBy": { "type": "string" },
          "organization": { "type": "string" },
          "tokenCostToSubmit": { "type": "integer" },
          "metadata": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
